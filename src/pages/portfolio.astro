---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="作品集" description="项目与成果图展示">
  <div class="page-header">
    <h1>作品集</h1>
    <p>项目与成果图展示。</p>
  </div>

  <section class="section">
    <h2>代表项目</h2>
    <div class="card">
      <h3>ysyx-prestudy</h3>
      <p class="card-desc">一生一芯预学习阶段的学习记录与代码仓库，包含 C 语言手搓的 RISC-V 指令集模拟器（minirvEMU）以及 Verilog RTL 实现探索。</p>
      <a href="https://github.com/helloworld-dlx/ysyx-prestudy" target="_blank" rel="noopener" class="card-link">
        → github.com/helloworld-dlx/ysyx-prestudy
      </a>
    </div>
  </section>

  <section class="section">
    <h2>成果图</h2>
    <div class="card">
      <h3>RISC-V 处理器仿真结构图</h3>
      <p class="card-desc">基于 Logisim 仿真的 8 条指令迷你 RISC-V 处理器（minirv），最终可以打印出"一生一芯"图标。</p>
      <div class="portfolio-grid">
        <img src="/portfolio-riscv-struct.png" alt="32位 RISC-V 处理器核心模块结构图" class="portfolio-img clickable" data-full="/portfolio-riscv-struct.png" />
      </div>
    </div>

    <div class="card">
      <h3>STC89C52RC 51单片机核心板</h3>
      <p class="card-desc">使用嘉立创EDA设计的51单片机核心板，USB-C供电、3.3V稳压、12MHz晶振、双层PCB布局，配有完整复位电路、用户LED与按键，全部GPIO引出排针。</p>
      <div class="portfolio-grid">
        <img src="/portfolio-51-pcb-3d.png" alt="51单片机核心板 PCB 3D渲染图" class="portfolio-img clickable" data-full="/portfolio-51-pcb-3d.png" />
        <img src="/portfolio-51-pcb-layout.png" alt="51单片机核心板 PCB 走线图" class="portfolio-img clickable" data-full="/portfolio-51-pcb-layout.png" />
        <img src="/portfolio-51-schematic.png" alt="51单片机核心板 原理图" class="portfolio-img clickable" data-full="/portfolio-51-schematic.png" />
      </div>
    </div>
  </section>

  <section class="section">
    <h2>代表文章</h2>
    <div class="card dashed">
      <p>（待添加）</p>
    </div>
  </section>

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox" role="dialog" aria-modal="true">
    <span class="lightbox-close" aria-label="关闭">&times;</span>
    <img id="lightbox-img" src="" alt="" />
  </div>

</BaseLayout>

<script>
  const lightbox = document.getElementById('lightbox')!;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const closeBtn = document.querySelector('.lightbox-close') as HTMLElement;

  document.querySelectorAll('.portfolio-img.clickable').forEach(img => {
    img.addEventListener('click', () => {
      const fullSrc = (img as HTMLImageElement).dataset.full || (img as HTMLImageElement).src;
      lightboxImg.src = fullSrc;
      lightboxImg.alt = (img as HTMLImageElement).alt;
      lightbox.classList.add('active');
    });
  });

  closeBtn.addEventListener('click', () => {
    lightbox.classList.remove('active');
  });

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) {
      lightbox.classList.remove('active');
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lightbox.classList.contains('active')) {
      lightbox.classList.remove('active');
    }
  });
</script>

<style>
  .page-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .page-header h1 {
    font-size: 1.5rem;
    margin-bottom: 0.375rem;
  }

  .page-header p {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .section {
    margin-bottom: 2rem;
  }

  h2 {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 0.875rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    margin-bottom: 1rem;
  }

  .card.dashed {
    border-style: dashed;
    text-align: center;
    justify-content: center;
  }

  .card.dashed p {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin: 0;
  }

  .card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.375rem;
  }

  .card-desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 0.75rem;
    flex: 1;
  }

  .card-link {
    font-size: 0.85rem;
    color: var(--color-accent);
    text-decoration: none;
    align-self: flex-start;
  }

  .card-link:hover {
    text-decoration: underline;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  .portfolio-img {
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .portfolio-img:hover {
    opacity: 0.8;
  }

  /* Lightbox styles */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
    z-index: 1000;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .lightbox.active {
    display: flex;
  }

  .lightbox img {
    max-width: 90vw;
    max-height: 90vh;
    border-radius: var(--radius);
    cursor: default;
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    font-size: 2rem;
    color: #fff;
    cursor: pointer;
    line-height: 1;
  }
</style>