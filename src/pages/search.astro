---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = await getCollection('posts');
const publishedPosts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const searchData = publishedPosts.map(post => ({
  id: post.id,
  title: post.data.title,
  description: post.data.description,
  tags: post.data.tags,
  date: post.data.date.toISOString(),
  section: post.data.section,
}));
---

<BaseLayout title="搜索" description="搜索文章">
  <div class="search-page">
    <div class="search-input-wrap">
      <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input
        type="search"
        id="search-input"
        placeholder="搜索..."
        autocomplete="off"
      />
    </div>

    <div id="results"></div>
  </div>

  <script define:vars={{ searchData }}>
    const input = document.getElementById('search-input');
    const results = document.getElementById('results');

    function renderPosts(posts) {
      if (posts.length === 0) {
        results.innerHTML = '<div class="no-results">未找到结果</div>';
        return;
      }
      results.innerHTML = '<div class="results-grid">' + posts.map(post => `
        <a href="/posts/${post.id}" class="result-item">
          <div class="result-date">${new Date(post.date).toLocaleDateString('zh-CN')}</div>
          <div class="result-title">${post.title}</div>
          <div class="result-tags">${post.tags.map(t => `<span>${t}</span>`).join('')}</div>
        </a>
      `).join('') + '</div>';
    }

    function search(query) {
      if (!query.trim()) {
        renderPosts(searchData);
        return;
      }
      const q = query.toLowerCase();
      const matched = searchData.filter(post =>
        post.title.toLowerCase().includes(q) ||
        post.description.toLowerCase().includes(q) ||
        post.tags.some(tag => tag.toLowerCase().includes(q))
      );
      renderPosts(matched);
    }

    renderPosts(searchData);
    input.addEventListener('input', e => search(e.target.value));
  </script>
</BaseLayout>

<style>
  .search-page {
    padding-top: 0.5rem;
  }

  .search-input-wrap {
    position: relative;
    margin-bottom: 2rem;
  }

  .search-icon {
    position: absolute;
    left: 0.875rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
  }

  input[type="search"] {
    width: 100%;
    padding: 0.75rem 0.875rem 0.75rem 2.75rem;
    font-size: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-surface);
    color: var(--color-text);
    transition: border-color 0.15s;
  }

  input[type="search"]:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  input[type="search"]::placeholder {
    color: var(--color-text-muted);
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0.75rem;
  }

  .result-item {
    display: flex;
    flex-direction: column;
    padding: 0.875rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .result-item:hover {
    border-color: var(--color-accent);
    box-shadow: 0 2px 8px rgba(74, 125, 155, 0.08);
  }

  .result-date {
    font-size: 0.725rem;
    color: var(--color-text-muted);
    margin-bottom: 0.375rem;
  }

  .result-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  .result-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-top: auto;
  }

  .result-tags span {
    font-size: 0.7rem;
    padding: 0.1rem 0.4rem;
    background: var(--color-bg-subtle, #f0f2f5);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    color: var(--color-text-muted);
  }

  .no-results {
    text-align: center;
    padding: 3rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
</style>