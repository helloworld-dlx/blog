---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = await getCollection('posts');
const publishedPosts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const searchData = publishedPosts.map(post => ({
  id: post.id,
  title: post.data.title,
  description: post.data.description,
  tags: post.data.tags,
  date: post.data.date.toISOString(),
}));
---

<BaseLayout title="搜索" description="搜索文章">
  <div class="search-page">
    <div class="search-input-wrap">
      <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input
        type="search"
        id="search-input"
        placeholder="输入关键词搜索..."
        autocomplete="off"
      />
    </div>

    <div id="results">
      <div class="empty-state">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <p>输入关键词开始搜索</p>
      </div>
    </div>
  </div>

  <script define:vars={{ searchData }}>
    const input = document.getElementById('search-input');
    const results = document.getElementById('results');

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function renderPosts(posts) {
      if (posts.length === 0) {
        results.innerHTML = `
          <div class="empty-state">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <p>没有找到匹配的文章</p>
          </div>`;
        return;
      }
      results.innerHTML = '<div class="results-grid">' + posts.map(post => `
        <a href="/posts/${post.id}" class="result-card">
          <div class="card-header">
            <span class="card-date">${new Date(post.date).toLocaleDateString('zh-CN')}</span>
          </div>
          <h3 class="card-title">${escapeHtml(post.title)}</h3>
          <p class="card-desc">${escapeHtml(post.description)}</p>
          <div class="card-tags">${post.tags.map(t => `<span>#${escapeHtml(t)}</span>`).join('')}</div>
        </a>
      `).join('') + '</div>';
    }

    function search(query) {
      if (!query.trim()) {
        results.innerHTML = `
          <div class="empty-state">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="11" cy="11" r="8"/>
              <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <p>输入关键词开始搜索</p>
          </div>`;
        return;
      }
      const q = query.toLowerCase();
      const matched = searchData.filter(post =>
        post.title.toLowerCase().includes(q) ||
        post.description.toLowerCase().includes(q) ||
        post.tags.some(tag => tag.toLowerCase().includes(q))
      );
      renderPosts(matched);
    }

    input.addEventListener('input', e => search(e.target.value));
  </script>
</BaseLayout>

<style>
  .search-page {
    padding-top: 0.5rem;
  }

  .search-input-wrap {
    position: relative;
    margin-bottom: 2rem;
  }

  .search-icon {
    position: absolute;
    left: 0.875rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
  }

  input[type="search"] {
    width: 100%;
    padding: 0.875rem 1rem 0.875rem 3rem;
    font-size: 1rem;
    border: 2px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-surface);
    color: var(--color-text);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  input[type="search"]:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(74, 125, 155, 0.1);
  }

  input[type="search"]::placeholder {
    color: var(--color-text-muted);
  }

  .empty-state {
    text-align: center;
    padding: 4rem 1rem;
    color: var(--color-text-muted);
  }

  .empty-state svg {
    margin-bottom: 1rem;
    opacity: 0.35;
  }

  .empty-state p {
    font-size: 1rem;
    margin: 0;
  }

  .results-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .results-grid {
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1rem;
    }
  }

  .result-card {
    display: flex;
    flex-direction: column;
    padding: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
    -webkit-transform: translateZ(0);
  }

  .result-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }

  .card-header {
    margin-bottom: 0.5rem;
  }

  .card-date {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .card-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.375rem;
    line-height: 1.4;
  }

  .card-desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0 0 0.625rem;
    line-height: 1.5;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: auto;
  }

  .card-tags span {
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    background: var(--color-bg-subtle, #f0f2f5);
    border-radius: 4px;
    color: var(--color-text-muted);
  }
</style>