---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到" description="您访问的页面不存在">
  <div class="not-found">
    <h1>404</h1>
    <p>页面不存在或已被移除</p>
    <a href="/">← 返回首页</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 4rem 0;
  }

  .not-found h1 {
    font-size: 4rem;
    font-weight: 700;
    color: var(--color-border);
    margin-bottom: 1rem;
  }

  .not-found p {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .not-found a {
    color: var(--color-accent);
    text-decoration: none;
    font-size: 0.9rem;
  }

  .not-found a:hover {
    text-decoration: underline;
  }
</style>
